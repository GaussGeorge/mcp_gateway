# Copy this file to .env and fill in values as needed.
# Mock experiments and unit tests do NOT require any real API keys.
# Only Tier 2 (real-LLM) experiments require provider credentials.

# LLM Provider (Tier 2/3 real-LLM experiments only)
# Supported backends (OpenAI-compatible):
#   GLM-4-Flash:  https://open.bigmodel.cn/api/paas/v4
#   DeepSeek:     https://api.deepseek.com/v1
#   Tongyi:       https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-4-flash

# Embedding (optional, defaults to sharing LLM_API_KEY)
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=

# Optional search tools (real_web_search.py)
TAVILY_API_KEY=
SERPAPI_KEY=

# Optional code sandbox (python_sandbox.py)
E2B_API_KEY=

# Gateway / Backend runtime configuration
GATEWAY_PORT=9200
BACKEND_PORT=8080
LOG_LEVEL=info